# Dockerfile de DESARROLLO (no producción): habilita hot-reload montando
# el código como volumen en docker-compose.yml, en vez de copiarlo dentro
# de la imagen. La imagen solo aporta Node y las dependencias instaladas.
FROM node:20

WORKDIR /app

COPY package*.json ./
RUN npm ci

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
